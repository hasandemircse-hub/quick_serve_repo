# Cloud DB
CLOUD_DB_NAME=quickserve
CLOUD_DB_USERNAME=quickserve
CLOUD_DB_PASSWORD=change_me

# Cloud security (HS256: en az 32 karakter / 256 bit — kısa secret login'de WeakKeyException verir)
CLOUD_JWT_SECRET=QuickServe2024SuperSecretKeyForJWTTokenGeneration32BytesMin!

# Kapalı lab: IDE'deki edge JWT göndermeden snapshot/garson/mutfak okusun. Spring: QUICKSERVE_DEV_INSECURE_EDGE_BRIDGE — prod'da false bırak.
QUICKSERVE_DEV_INSECURE_EDGE_BRIDGE=false

# Cloud web
CLOUD_FRONTEND_URL=http://localhost
CLOUD_CORS_ORIGINS=http://localhost

# Superadmin bootstrap
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change_me
SUPERADMIN_EMAIL=superadmin@quickserve.local
SUPERADMIN_PHONE=05000000000

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
