# Veritabanı
DB_USERNAME=quickserve
DB_PASSWORD=change_me_strong_password

# JWT (en az 32 karakter)
JWT_SECRET=change_me_very_long_secret_key_at_least_32_chars

# Kapalı lab: IDE edge EDGE_SKIP_CLOUD_JWT=true iken cloud bu true olmalı (internet prod'da false).
QUICKSERVE_DEV_INSECURE_EDGE_BRIDGE=false

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Mail (SMTP)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Netgsm SMS
NETGSM_USERCODE=your-netgsm-usercode
NETGSM_PASSWORD=your-netgsm-password
NETGSM_HEADER=YOURAPP

# Superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change_me_strong_password
SUPERADMIN_EMAIL=admin@yourcompany.com
SUPERADMIN_PHONE=+905001234567
