# ─── VS Code / IDE (edge-backend Run) ───────────────────────────────────────
# Bu dosyayı repo kökünde `.env.edge` olarak kopyala; `.vscode/launch.json` edge Java
# için `envFile` olarak `.env.edge` okur (Spring env: EDGE_CLOUD_BASE_URL vb.).
# Mac geliştirme SQLite:
#   EDGE_SQLITE_PATH=./data/edge.db
# Cloud VM örneği:
#   EDGE_CLOUD_BASE_URL=http://192.168.139.157/api
#   EDGE_RESTAURANT_ID=1
#   EDGE_NODE_ID=edge-dev-mac
# Cloud'dan veri çekmek için SADECE şunu doldur: EDGE_BRIDGE_JWT_TOKEN = claim yanıtındaki uzun anahtar (eyJ...).
# EDGE_ENROLLMENT_TOKEN = paneldeki kısa davet kodu; edge-backend bunu OKUMAZ. Sadece docker-compose'a
# aktarılır / script notu; VS Code'dan edge çalıştırırken boş veya eski kalabilir, uygulamayı etkilemez.

# edge-frontend: tarayıcının göreceği API adresleri (docker compose --build ile gömülür)
EDGE_API_URL=http://127.0.0.1:8081/api
CLOUD_API_URL=http://127.0.0.1:8080/api
# EDGE_FRONTEND_PORT=8082

# Edge identity
EDGE_NODE_ID=edge-001
EDGE_RESTAURANT_ID=1
EDGE_CLOUD_BASE_URL=https://cloud.quickserve.example/api
EDGE_BRIDGE_JWT_TOKEN=
# Aşağıdaki satır edge Java kodunda kullanılmıyor (kafa karıştırmasın diye not).
# İlk açılışta ve periyodik cloud snapshot (offline okuma: masalar, menü, mutfak vb.)
EDGE_BOOTSTRAP_PULL_ON_STARTUP=true
EDGE_BOOTSTRAP_PULL_INTERVAL_MS=900000
# IDE (Mac): ./data/edge.db — Docker edge container içinde yol docker-compose’ta /data/edge.db sabit.
EDGE_SQLITE_PATH=./data/edge.db
EDGE_ENROLLMENT_TOKEN=
EDGE_IMAGE_REPOSITORY=ghcr.io/hasandemircse-hub/quick_serve/quickserve-edge-backend
EDGE_IMAGE_TAG=latest
# Opsiyonel: deploy_edge_release.sh health probe (varsayılan http://127.0.0.1:8081/api/actuator/health)
# EDGE_HEALTH_URL=http://127.0.0.1:8081/api/actuator/health
EDGE_SYNC_INTERVAL_MS=5000
EDGE_SYNC_WORKER_ENABLED=true
EDGE_SYNC_BATCH_SIZE=50
EDGE_SYNC_MAX_RETRY=10
EDGE_SYNC_BASE_BACKOFF_SECONDS=5
EDGE_SYNC_MAINTENANCE_ENABLED=true
EDGE_SYNC_MAINTENANCE_INTERVAL_MS=3600000
EDGE_SYNC_RETENTION_SENT_DAYS=3
EDGE_SYNC_RETENTION_DEAD_DAYS=14
EDGE_SYNC_RETENTION_INBOX_PROCESSED_DAYS=7
EDGE_SYNC_RETENTION_INBOX_DEAD_DAYS=14
EDGE_POS_DEFAULT_PROVIDER=mock-pos
EDGE_POS_HTTP_ENABLED=false
EDGE_POS_HTTP_PROVIDER_CODE=http-pos
EDGE_POS_HTTP_BASE_URL=
EDGE_POS_HTTP_CHARGE_PATH=/charge
EDGE_POS_HTTP_BEARER_TOKEN=
EDGE_POS_HTTP_API_KEY_HEADER=X-API-Key
EDGE_POS_HTTP_API_KEY_VALUE=
EDGE_POS_HTTP_RESPONSE_SUCCESS_FIELD=success
EDGE_POS_HTTP_RESPONSE_SUCCESS_VALUE=true
EDGE_POS_HTTP_RESPONSE_TX_ID_FIELDS=transactionId,txId,id
EDGE_POS_HTTP_RESPONSE_MESSAGE_FIELDS=message,statusMessage
EDGE_POS_HTTP_RESPONSE_ERROR_CODE_FIELDS=errorCode,code
EDGE_POS_HTTP_RESPONSE_RETRYABLE_FIELD=retryable
EDGE_POS_HTTP_CONNECT_TIMEOUT_MS=3000
EDGE_POS_HTTP_READ_TIMEOUT_MS=8000
# POS idempotency audit tablosu retention (gün); 0 = purge kapalı
EDGE_POS_AUDIT_RETENTION_DAYS=90
EDGE_PRINTER_DEFAULT_PROVIDER=mock-printer
